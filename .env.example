# ====================================================================
# Taswerak | تصويرك — Environment Variables
# Copy to .env and fill in real values before running.
# ====================================================================

# -------- App --------
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
HOSTNAME=0.0.0.0
PORT=3000

# -------- Database (PostgreSQL only) --------
# Pool URL (used by Prisma Client at runtime — pgbouncer or direct)
DATABASE_URL="postgresql://taswerak:taswerak@localhost:5432/taswerak?schema=public"
# Direct URL (used by Prisma Migrate — must bypass pgbouncer)
DIRECT_URL="postgresql://taswerak:taswerak@localhost:5432/taswerak?schema=public"

# -------- Auth.js v5 --------
AUTH_SECRET=change-me-to-another-long-random-string
AUTH_TRUST_HOST=true
# Optional OAuth (disabled by default — manual flow is primary)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -------- MinIO (S3-compatible object storage) --------
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=taswerak_minio
MINIO_SECRET_KEY=taswerak_minio_secret
MINIO_BUCKET=taswerak-uploads
MINIO_PUBLIC_URL=http://localhost:9000

# -------- Email (simulation in dev; nodemailer SMTP in prod) --------
EMAIL_FROM="Taswerak <no-reply@taswerak.com>"
EMAIL_TRANSPORT=simulation   # simulation | smtp
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# -------- Bank Details (shown to students on manual payment page) --------
BANK_NAME=البنك الأهلي السعودي
BANK_ACCOUNT_NAME=أحمد زغلول - تصويرك
BANK_IBAN=SA00 0000 0000 0000 0000 0000
BANK_ACCOUNT_NUMBER=0000000000000

# -------- App Branding --------
APP_NAME=تصويرك
APP_NAME_EN=Taswerak
APP_LOGO_URL=/logo.png
APP_GRADIENT_FROM=#0A9ED9
APP_GRADIENT_MID=#00A3AA
APP_GRADIENT_TO=#D65221
APP_CITY=جدة
APP_COUNTRY=السعودية

# -------- Feature Flags --------
ENABLE_SIGNUP=true
ENABLE_IMPERSONATION=true
ENABLE_CERTIFICATES=true
