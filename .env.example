# ====================================================================
# Taswerak | تصويرك — Environment Variables
# Copy to .env and fill in real values before running.
# ====================================================================

# -------- App --------
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
HOSTNAME=0.0.0.0
PORT=3000

# -------- Database (PostgreSQL only) --------
# Pool URL (used by Prisma Client at runtime — pgbouncer or direct)
DATABASE_URL="postgresql://taswerak:taswerak@localhost:5432/taswerak?schema=public"
# Direct URL (used by Prisma Migrate — must bypass pgbouncer)
DIRECT_URL="postgresql://taswerak:taswerak@localhost:5432/taswerak?schema=public"

# -------- Auth.js v5 --------
AUTH_SECRET=change-me-to-another-long-random-string
AUTH_TRUST_HOST=true
# Optional OAuth (disabled by default — manual flow is primary)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -------- MinIO (S3-compatible object storage) --------
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=taswerak_minio
MINIO_SECRET_KEY=taswerak_minio_secret
MINIO_BUCKET=taswerak-uploads
MINIO_PUBLIC_URL=http://localhost:9000

# -------- Email (simulation in dev; nodemailer SMTP in prod) --------
EMAIL_FROM="Taswerak <no-reply@taswerak.com>"
EMAIL_TRANSPORT=simulation   # simulation | smtp
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# -------- Bank Details (shown to students on manual payment page) --------
BANK_NAME=البنك الأهلي السعودي
BANK_ACCOUNT_NAME=أحمد زغلول - تصويرك
BANK_IBAN=SA00 0000 0000 0000 0000 0000
BANK_ACCOUNT_NUMBER=0000000000000

# -------- App Branding --------
APP_NAME=تصويرك
APP_NAME_EN=Taswerak
APP_LOGO_URL=/logo.png
APP_GRADIENT_FROM=#0A9ED9
APP_GRADIENT_MID=#00A3AA
APP_GRADIENT_TO=#D65221
APP_CITY=جدة
APP_COUNTRY=السعودية

# -------- Feature Flags --------
ENABLE_SIGNUP=true
ENABLE_IMPERSONATION=true
ENABLE_CERTIFICATES=true

# -------- Payment Gateways (manual is always available) --------
# Currently active: MANUAL (bank transfer)
# When you get merchant accounts, set the keys below + update
# PAYMENT_GATEWAY env var to "moyasar", "tap", "bitaps", "tamara", or "tabby"

# Default gateway used at checkout (manual | moyasar | tap)
PAYMENT_GATEWAY=manual

# Moyasar (https://moyasar.com) — Mada, Visa, Mastercard, Apple Pay
MOYASAR_SECRET_KEY=
MOYASAR_PUBLIC_KEY=

# Tap (https://tap.company) — All cards + Apple Pay + STC Pay
TAP_SECRET_KEY=
TAP_MERCHANT_ID=

# Bitaps, Tamara, Tabby — add when merchant accounts ready
# BITAPS_API_KEY=
# TAMARA_API_KEY=
# TABBY_API_KEY=

# -------- WhatsApp (Whapi.cloud or Meta Cloud API) --------
# Option 1: Whapi.cloud (recommended — easier setup)
# Create account at https://whapi.cloud → get API key
WHAPI_API_KEY=

# Option 2: WhatsApp Cloud API (Meta)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Your WhatsApp Business number (for click-to-chat links)
WHATSAPP_NUMBER=

# -------- Google Analytics 4 --------
# Create property at https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# -------- Sentry (error tracking) --------
# Create project at https://sentry.io
SENTRY_DSN=

# -------- Google Search Console verification --------
GOOGLE_SITE_VERIFICATION=
