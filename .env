# Local development .env — DO NOT COMMIT REAL SECRETS
# Use .env.example as template for production

NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev_secret_change_me_in_production_min_32_chars_long
AUTH_SECRET=dev_auth_secret_change_me_min_32_chars_long
AUTH_TRUST_HOST=true
HOSTNAME=0.0.0.0
PORT=3000

DATABASE_URL="postgresql://taswerak:taswerak@localhost:5432/taswerak?schema=public"
DIRECT_URL="postgresql://taswerak:taswerak@localhost:5432/taswerak?schema=public"

MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=taswerak_minio
MINIO_SECRET_KEY=taswerak_minio_secret
MINIO_BUCKET=taswerak-uploads
MINIO_PUBLIC_URL=http://localhost:9000

EMAIL_FROM="Taswerak <no-reply@taswerak.com>"
EMAIL_TRANSPORT=simulation

BANK_NAME=البنك الأهلي السعودي
BANK_ACCOUNT_NAME=أحمد زغلول - تصويرك
BANK_IBAN=SA00 0000 0000 0000 0000 0000
BANK_ACCOUNT_NUMBER=0000000000000

APP_NAME=تصويرك
APP_NAME_EN=Taswerak
APP_LOGO_URL=/logo.png
APP_GRADIENT_FROM=#0A9ED9
APP_GRADIENT_MID=#00A3AA
APP_GRADIENT_TO=#D65221
APP_CITY=جدة
APP_COUNTRY=السعودية

ENABLE_SIGNUP=true
ENABLE_IMPERSONATION=true
ENABLE_CERTIFICATES=true
